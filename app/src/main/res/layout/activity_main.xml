<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="20dp"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Action Assistant"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:fontFamily="@font/fredoka"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hands-free communication parser"
        android:textColor="#D1D5DB"
        android:textSize="12sp"
        android:fontFamily="@font/fredoka"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp" />

    <!-- Accessibility Status Indicator -->
    <LinearLayout
        android:id="@+id/layoutServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_glass_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#EF4444"
            android:backgroundTint="#EF4444" />

        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Accessibility Service: Disabled"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:fontFamily="@font/fredoka"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnEnableService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETUP"
            android:textSize="11sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#14B8A6"/>
    </LinearLayout>

    <!-- Language Selector Panel -->
    <TextView
        android:id="@+id/tvLanguageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DICTATION LANGUAGE"
        android:textColor="#14B8A6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="@font/fredoka"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutServiceStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rgLanguages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_glass_bg"
        android:padding="8dp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvLanguageTitle">

        <RadioButton
            android:id="@+id/rbEnglish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="English"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:checked="true"
            android:buttonTint="#14B8A6"/>

        <RadioButton
            android:id="@+id/rbSpanish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Español"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:buttonTint="#14B8A6"/>

        <RadioButton
            android:id="@+id/rbTamil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="தமிழ்"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:buttonTint="#14B8A6"/>
    </RadioGroup>

    <!-- Voice Dashboard Hub (Glassmorphic Container replacing the terminal) -->
    <LinearLayout
        android:id="@+id/cardDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/card_glass_bg"
        android:orientation="vertical"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/rgLanguages"
        app:layout_constraintBottom_toTopOf="@id/tvMicStatus">

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="16dp"
            android:clipToPadding="false"
            android:scrollbarStyle="outsideOverlay">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Section 1: Suggestions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUGGESTIONS"
                android:textColor="#5EEAD4"
                android:textSize="11sp"
                android:fontFamily="@font/fredoka"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Suggestion 1 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Send hi to Mummy"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 2 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🇪🇸 Enviar hola a Mamá"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 3 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Send ready to boss"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 4 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✈️ Telegram hello to Boss"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 5 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📧 Email update to Team"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 6 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard6"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 SMS I am driving"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Section: Favorites -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAVORITE CONTACTS"
                android:textColor="#5EEAD4"
                android:textSize="11sp"
                android:fontFamily="@font/fredoka"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <!-- Favorite 1: Mummy (Constant WhatsApp) -->
                <LinearLayout
                    android:id="@+id/favContactMummy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:layout_marginBottom="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="#1A2DD4BF"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="M"
                            android:textColor="#5EEAD4"
                            android:textSize="14sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mummy"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Constant • WhatsApp contact"
                            android:textColor="#D1D5DB"
                            android:textSize="10sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟢 WhatsApp"
                        android:textColor="#5EEAD4"
                        android:textSize="11sp"
                        android:fontFamily="@font/fredoka"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/card_glass_bg"/>
                </LinearLayout>

                <!-- Favorite 2: Dad (Constant SMS) -->
                <LinearLayout
                    android:id="@+id/favContactDad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:layout_marginBottom="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="#1A2DD4BF"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="D"
                            android:textColor="#5EEAD4"
                            android:textSize="14sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dad"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Constant • SMS contact"
                            android:textColor="#D1D5DB"
                            android:textSize="10sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬 SMS"
                        android:textColor="#5EEAD4"
                        android:textSize="11sp"
                        android:fontFamily="@font/fredoka"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/card_glass_bg"/>
                </LinearLayout>

                <!-- Favorite 3: Boss (Suggested Telegram) -->
                <LinearLayout
                    android:id="@+id/favContactBoss"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:layout_marginBottom="8dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        app:cardCornerRadius="18dp"
                        app:cardBackgroundColor="#1A2DD4BF"
                        app:cardElevation="0dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="B"
                            android:textColor="#5EEAD4"
                            android:textSize="14sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Boss"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Suggested • Telegram contact"
                            android:textColor="#D1D5DB"
                            android:textSize="10sp"
                            android:fontFamily="@font/fredoka"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✈️ Telegram"
                        android:textColor="#5EEAD4"
                        android:textSize="11sp"
                        android:fontFamily="@font/fredoka"
                        android:textStyle="bold"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:background="@drawable/card_glass_bg"/>
                </LinearLayout>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#26FFFFFF"
                android:layout_marginBottom="16dp"/>

            <!-- Section 2: Recent History -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT ACTIONS"
                android:textColor="#5EEAD4"
                android:textSize="11sp"
                android:fontFamily="@font/fredoka"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:id="@+id/layoutRecentHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Default placeholder view if no history -->
                <TextView
                    android:id="@+id/tvHistoryPlaceholder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recent actions.\nTap the microphone and speak a command to start!"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:lineSpacingExtra="3dp"
                    android:gravity="center"
                    android:layout_marginTop="48dp"
                    android:fontFamily="@font/fredoka"/>

            </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

    <!-- Mic State View -->
    <TextView
        android:id="@+id/tvMicStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap microphone to speak"
        android:textColor="#5EEAD4"
        android:textSize="14sp"
        android:fontFamily="@font/fredoka"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/layoutMicContainer"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="12dp"/>

    <!-- Large Mic Button Frame with pulsing glow ring -->
    <FrameLayout
        android:id="@+id/layoutMicContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/cardConfirmation"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_mic_outer_glow"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:backgroundTint="#14B8A6"
            android:src="@android:drawable/ic_btn_speak_now"
            app:fabCustomSize="80dp"
            app:tint="#F9FAFB"
            android:contentDescription="Start voice recognition"
            app:elevation="8dp"/>
    </FrameLayout>

    <!-- Confirmation / Edit Card -->
    <LinearLayout
        android:id="@+id/cardConfirmation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/card_glass_bg"
        android:visibility="gone"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Action Pending Confirmation"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="@font/fredoka"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp"
            android:background="@drawable/card_glass_bg"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Contact: "
                android:textColor="#D1D5DB"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvConfirmRecipient"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="John Doe"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="@font/fredoka"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  •  App: "
                android:textColor="#D1D5DB"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvConfirmApp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WhatsApp"
                android:textColor="#14B8A6"
                android:textSize="13sp"
                android:fontFamily="@font/fredoka"
                android:textStyle="bold"/>
        </LinearLayout>

        <EditText
            android:id="@+id/etConfirmMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1AFFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:padding="12dp"
            android:minLines="3"
            android:gravity="top|start"
            android:hint="Edit draft message..."
            android:textColorHint="#4B5563"
            android:inputType="textMultiLine"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnCancelSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DISCARD"
                android:textColor="#EF4444"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnConfirmSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SEND ACTION"
                android:textSize="11sp"
                android:textStyle="bold"
                android:backgroundTint="#14B8A6"
                android:textColor="#F9FAFB"
                app:cornerRadius="10dp"/>
        </LinearLayout>
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>
