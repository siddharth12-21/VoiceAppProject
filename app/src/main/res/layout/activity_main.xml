<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="24dp"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Assistant"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="24dp" />

    <!-- Accessibility Status Indicator -->
    <LinearLayout
        android:id="@+id/layoutServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1E1E1E"
        android:padding="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="#FF5722"
            android:backgroundTint="#FF5722"/>

        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Accessibility Service: Disabled"
            android:textColor="#E0E0E0"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btnEnableService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enable"
            android:textSize="12sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#BB86FC"/>
    </LinearLayout>

    <!-- Language Selector Panel -->
    <TextView
        android:id="@+id/tvLanguageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Dictation Language"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/layoutServiceStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rgLanguages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvLanguageTitle">

        <RadioButton
            android:id="@+id/rbEnglish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="English 🇺🇸"
            android:textColor="#E0E0E0"
            android:checked="true"
            android:buttonTint="#BB86FC"
            android:layout_marginEnd="8dp"/>

        <RadioButton
            android:id="@+id/rbSpanish"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Español 🇪🇸"
            android:textColor="#E0E0E0"
            android:buttonTint="#BB86FC"
            android:layout_marginEnd="8dp"/>

        <RadioButton
            android:id="@+id/rbTamil"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="தமிழ் 🇮🇳"
            android:textColor="#E0E0E0"
            android:buttonTint="#BB86FC"
            android:layout_marginEnd="8dp"/>
    </RadioGroup>

    <!-- Mic State View -->
    <TextView
        android:id="@+id/tvMicStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap microphone to speak"
        android:textColor="#BB86FC"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintBottom_toTopOf="@id/btnMic"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="24dp"/>

    <!-- Large Mic Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnMic"
        android:layout_width="84dp"
        android:layout_height="84dp"
        android:backgroundTint="#BB86FC"
        android:src="@android:drawable/ic_btn_speak_now"
        app:fabCustomSize="84dp"
        app:tint="#121212"
        app:layout_constraintBottom_toTopOf="@id/cardConfirmation"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="32dp"
        android:contentDescription="Start voice recognition"/>

    <!-- Confirmation / Edit Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardConfirmation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1E1E1E"
        app:cardCornerRadius="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirm Message Delivery"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send to: "
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/tvConfirmRecipient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" via "
                    android:textColor="#AAAAAA"
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"/>

                <TextView
                    android:id="@+id/tvConfirmApp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textColor="#03DAC6"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etConfirmMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#2C2C2C"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:padding="12dp"
                android:minLines="3"
                android:gravity="top|start"
                android:hint="Type message here..."
                android:textColorHint="#666666"
                android:inputType="textMultiLine"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnCancelSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cancel"
                    android:textColor="#CF6679"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnConfirmSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Send Now"
                    android:backgroundTint="#03DAC6"
                    android:textColor="#121212"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Test Text Command Input Panel (for testing on emulators without microphone input) -->
    <LinearLayout
        android:id="@+id/layoutTestInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="8dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/rgLanguages">

        <EditText
            android:id="@+id/etTestCommand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Or type test command..."
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="#2C2C2C"
            android:padding="8dp"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnTestParse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parse"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#BB86FC"
            android:textColor="#121212"/>
    </LinearLayout>

    <!-- Console / Live Transcription View -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTestInput"
        app:layout_constraintBottom_toTopOf="@id/tvMicStatus">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready for voice instruction..."
            android:textColor="#888888"
            android:textSize="13sp"
            android:fontFamily="monospace"/>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
