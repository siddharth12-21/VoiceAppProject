<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:padding="20dp"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Voice Action Assistant"
        android:textColor="#F9FAFB"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hands-free communication parser"
        android:textColor="#9CA3AF"
        android:textSize="12sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="2dp" />

    <!-- Accessibility Status Indicator -->
    <LinearLayout
        android:id="@+id/layoutServiceStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_glass_bg"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#EF4444"
            android:backgroundTint="#EF4444" />

        <TextView
            android:id="@+id/tvServiceStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Accessibility Service: Disabled"
            android:textColor="#E5E7EB"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btnEnableService"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETUP"
            android:textSize="11sp"
            android:textStyle="bold"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="#8B5CF6"/>
    </LinearLayout>

    <!-- Language Selector Panel -->
    <TextView
        android:id="@+id/tvLanguageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DICTATION LANGUAGE"
        android:textColor="#8B5CF6"
        android:textSize="11sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/layoutServiceStatus"
        app:layout_constraintStart_toStartOf="parent"/>

    <RadioGroup
        android:id="@+id/rgLanguages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/card_glass_bg"
        android:padding="8dp"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvLanguageTitle">

        <RadioButton
            android:id="@+id/rbEnglish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="English"
            android:textSize="12sp"
            android:textColor="#E5E7EB"
            android:checked="true"
            android:buttonTint="#8B5CF6"/>

        <RadioButton
            android:id="@+id/rbSpanish"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Español"
            android:textSize="12sp"
            android:textColor="#E5E7EB"
            android:buttonTint="#8B5CF6"/>

        <RadioButton
            android:id="@+id/rbTamil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="தமிழ்"
            android:textSize="12sp"
            android:textColor="#E5E7EB"
            android:buttonTint="#8B5CF6"/>
    </RadioGroup>

    <!-- Voice Dashboard Hub (Glassmorphic Container replacing the terminal) -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDashboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="#0D0B14"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/rgLanguages"
        app:layout_constraintBottom_toTopOf="@id/tvMicStatus">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Suggestions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SUGGESTIONS"
                android:textColor="#A78BFA"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Suggestion 1 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Send hi to Mummy"
                            android:textColor="#F9FAFB"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="sans-serif-medium"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 2 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🇪🇸 Enviar hola a Mamá"
                            android:textColor="#F9FAFB"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="sans-serif-medium"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Suggestion 3 -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/suggestCard3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#171324"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?android:attr/selectableItemBackground">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Send ready to boss"
                            android:textColor="#F9FAFB"
                            android:textSize="12sp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:fontFamily="sans-serif-medium"/>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#221C35"
                android:layout_marginBottom="16dp"/>

            <!-- Section 2: Recent History -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECENT ACTIONS"
                android:textColor="#A78BFA"
                android:textSize="11sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/layoutRecentHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Default placeholder view if no history -->
                    <TextView
                        android:id="@+id/tvHistoryPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No recent actions.\nTap the microphone and speak a command to start!"
                        android:textColor="#4B5563"
                        android:textSize="12sp"
                        android:lineSpacingExtra="3dp"
                        android:gravity="center"
                        android:layout_marginTop="48dp"
                        android:fontFamily="sans-serif"/>

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Mic State View -->
    <TextView
        android:id="@+id/tvMicStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap microphone to speak"
        android:textColor="#A78BFA"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/layoutMicContainer"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="12dp"/>

    <!-- Large Mic Button Frame with pulsing glow ring -->
    <FrameLayout
        android:id="@+id/layoutMicContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/cardConfirmation"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginBottom="20dp">

        <View
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_mic_outer_glow"/>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/btnMic"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:backgroundTint="#8B5CF6"
            android:src="@android:drawable/ic_btn_speak_now"
            app:fabCustomSize="80dp"
            app:tint="#F9FAFB"
            android:contentDescription="Start voice recognition"
            app:elevation="8dp"/>
    </FrameLayout>

    <!-- Confirmation / Edit Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardConfirmation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#171324"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Action Pending Confirmation"
                android:textColor="#F9FAFB"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:background="#221C35"
                android:padding="10dp"
                android:backgroundTint="#221C35">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact: "
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvConfirmRecipient"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textColor="#F9FAFB"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  •  App: "
                    android:textColor="#9CA3AF"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/tvConfirmApp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textColor="#10B981"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-black"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etConfirmMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#0D0B14"
                android:textColor="#F9FAFB"
                android:textSize="14sp"
                android:padding="12dp"
                android:minLines="3"
                android:gravity="top|start"
                android:hint="Edit draft message..."
                android:textColorHint="#4B5563"
                android:inputType="textMultiLine"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnCancelSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISCARD"
                    android:textColor="#EF4444"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnConfirmSend"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SEND ACTION"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:backgroundTint="#10B981"
                    android:textColor="#F9FAFB"
                    app:cornerRadius="10dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>



</androidx.constraintlayout.widget.ConstraintLayout>
